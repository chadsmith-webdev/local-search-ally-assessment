ASSESSMENT_STORE_ADAPTER=memory

# Use postgres for Supabase-backed persistence.
# ASSESSMENT_STORE_ADAPTER=postgres
# DATABASE_URL=postgres://postgres.project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DATABASE_SCHEMA=public

# PayPal sandbox checkout only. Never expose secret or webhook values as NEXT_PUBLIC variables.
# PAYPAL_ENV=sandbox
# PAYPAL_CLIENT_ID=paypal-sandbox-client-id
# PAYPAL_CLIENT_SECRET=paypal-sandbox-client-secret
# PAYPAL_WEBHOOK_ID=paypal-sandbox-webhook-id
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=paypal-sandbox-client-id
# APP_BASE_URL=https://your-vercel-preview-or-domain.example

# Resend transactional email. Never expose these through NEXT_PUBLIC variables.
# RESEND_API_KEY=resend-api-key
# RESEND_FROM_EMAIL=Local Search Ally <assessment@your-domain.example>
# RESEND_REPLY_TO_EMAIL=support@your-domain.example
# RESEND_WEBHOOK_SECRET=resend-webhook-signing-secret

# Launch hardening guards. Leave unset in normal production.
# ENABLE_DEVELOPMENT_FIXTURE_ROUTES=false
# ENABLE_SANDBOX_CHECKOUT_PREVIEW=false
